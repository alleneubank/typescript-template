{
  "name": "typescript-template",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "build": "bun run --filter './packages/*' build && bun run --filter './apps/*' build",
    "typecheck": "tsgo -b",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "knip": "knip",
    "jscpd": "jscpd .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@typescript/native-preview": "^7.0.0-dev.20260524.1",
    "jscpd": "^4.2.3",
    "knip": "^5.88.1",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.9.3",
    "zshy": "^0.7.2"
  }
}
